# ═══════════════════════════════════════════════════
# PLACEONIX BACKEND - ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════
# Copy this to .env and edit values for your environment.

# ─── Server ───
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ─── Database ───
MONGO_URI=mongodb://localhost:27017/placeonix-hub
# For Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/placeonix-hub

# ─── JWT (Authentication) ───
# MUST be 32+ characters and different from each other
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-chars
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-change-this-too-32-chars
JWT_REFRESH_EXPIRE=30d
JWT_COOKIE_EXPIRE=7

# ─── Email (for notifications, password reset) ───
# Leave SMTP_HOST empty to skip emails (they will be logged instead)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=admissions@placeonix.in
SMTP_PASS=your-app-password
EMAIL_FROM=Placeonix <admissions@placeonix.in>

# ─── CORS ───
# Frontend URLs allowed to call this API. Comma-separated. Use * for any (dev only).
CLIENT_URL=http://localhost:3000

# ─── Rate Limiting ───
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ─── File Upload ───
MAX_FILE_UPLOAD=10
FILE_UPLOAD_PATH=./uploads

# ─── Background Jobs ───
# Set to 'true' to disable all cron jobs (useful during testing)
DISABLE_CRON=false
